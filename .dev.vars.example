# Local-only secrets for `wrangler dev` (copy to .dev.vars, do not commit).
# In production set these via `wrangler secret put <NAME>`.

# Cloudflare Turnstile secret key (server-side verify, /api/upload/sign).
# Local dev: use the documented ALWAYS-PASS test secret so the upload flow is
# exercisable offline. It pairs with the test SITE key in wrangler.jsonc
# (PUBLIC_TURNSTILE_SITE_KEY = 1x00000000000000000000AA).
# Production: replace with the real secret from the Turnstile dashboard.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# R2 credentials are NO LONGER required for uploads — the Worker writes to the
# bound R2 `BUCKET` directly (binding-proxy upload, see src/server/r2/images.ts),
# so there are no S3 presigned-URL credentials to manage for the MVP. Left here
# (empty) only if a future presigned path is reintroduced.
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ACCOUNT_ID=

# Maintainer admin local-dev mock (R7 / ADR-11). In PRODUCTION the /admin page +
# /api/admin/* endpoints are gated by Cloudflare Access at the edge (no env var
# needed — Access injects Cf-Access-Authenticated-User-Email). LOCAL dev has no
# Access edge, so set this to any email to mock an authenticated maintainer; the
# admin guard (src/middleware.ts → src/server/admin-auth.ts) then lets you in.
# Leave it UNSET to test the unauthorized path (/admin returns 403). NEVER set
# this in production — it would bypass the edge SSO gate.
DEV_ADMIN_EMAIL=maintainer@example.com
