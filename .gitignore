# === Dependencies ===
node_modules/
.pnpm-store/
jspm_packages/

# === Build output ===
dist/
build/
out/
.astro/
.output/
*.tsbuildinfo

# === Cloudflare / Wrangler ===
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example

# === Drizzle ===
# drizzle-kit migrations should be committed; only ignore generated meta
drizzle/.drizzle/
.drizzle/

# === Environment variables ===
# `.env.development` / `.env.production` hold only PUBLIC_* build-time vars (the
# values are inlined into the client bundle and shipped to every browser), so they
# are NON-secret and COMMITTED. Secrets never go here (server secrets → .dev.vars
# / `wrangler secret`). Local overrides (.env.local, .env.*.local) stay ignored.
.env
.env.*
!.env.example
!.env.template
!.env.development
!.env.production

# === Logs ===
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# === Test / Coverage ===
coverage/
.nyc_output/
*.lcov

# === Playwright MCP (browser-driver output: snapshots / traces / screenshots) ===
.playwright-mcp/

# === Editor / IDE ===
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# === Python (Trellis scripts cache) ===
__pycache__/
*.pyc
*.pyo
*.pyd

# === AI development scaffolding (local-only; NOT part of the open-source repo) ===
# Trellis workflow + Claude/Codex agent config assist local development but are
# intentionally untracked so the public repo stays focused on the product. The
# local files are kept on disk — only their git tracking is removed. Delete a
# line below if you ever decide to publish that tool.
.trellis/
.claude/
.codex/
.agents/
skills-lock.json
AGENTS.md

# === Coordinate-migration artifacts (scripts/migrate-coords-frame-to-image.mjs) ===
# Timestamped pre-migration backups + generated UPDATE/rollback SQL are
# operational outputs, not source. Keep the directory tracked (.gitkeep) so the
# script's mkdir target is documented, but never commit the run artifacts (the
# prod backup is the rollback safety net — archive it out-of-band).
scripts/backups/*
!scripts/backups/.gitkeep

# === Misc temp files ===
*.tmp
*.bak
*.orig
