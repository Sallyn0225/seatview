{
  "name": "seatmap-real",
  "version": "0.0.1",
  "description": "SeatView — aggregated real-seat-view photo atlas for Japanese concert venues (internal codename: seatmap-real).",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro build && wrangler dev -c dist/server/wrangler.json",
    "deploy": "astro build && wrangler deploy -c dist/server/wrangler.json",
    "test": "node --experimental-strip-types --test \"src/**/*.test.ts\"",
    "astro": "astro",
    "typecheck": "astro check",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css}\" \"scripts/**/*.{mjs,js}\" \"*.{ts,mjs}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css}\" \"scripts/**/*.{mjs,js}\" \"*.{ts,mjs}\"",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply seatmap-real --local",
    "db:migrate:prod": "wrangler d1 migrations apply seatmap-real --remote",
    "db:seed:local": "wrangler d1 execute seatmap-real --local --file=./seeds/0001_demo_photos.sql",
    "gen:seatmaps": "node scripts/gen-placeholder-seatmaps.mjs",
    "gen:seed": "node scripts/gen-demo-seed.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^5.0.7",
    "@giscus/react": "^3.1.0",
    "astro": "^6.4.6",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.0",
    "fuse.js": "^7.4.2",
    "libheif-js": "^1.19.8",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-photo-album": "^3.0.2",
    "react-zoom-pan-pinch": "^4.0.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "yet-another-react-lightbox": "^3.21.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@cloudflare/workers-types": "^4.20260613.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "vite": "^7.3.2",
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    },
    "yaml": "^2.9.0"
  }
}
